package frc.robot.subsystems;

import com.revrobotics.CANSparkMax;
import com.revrobotics.RelativeEncoder;
import com.revrobotics.SparkPIDController;
import com.revrobotics.CANSparkBase.ControlType;
import com.revrobotics.CANSparkBase.IdleMode;
import com.revrobotics.CANSparkLowLevel.MotorType;

import edu.wpi.first.wpilibj.smartdashboard.SmartDashboard;
import edu.wpi.first.wpilibj2.command.SubsystemBase;
import frc.robot.Constants.PivotConstants;

public class PivotSubsystem extends SubsystemBase {
    private final CANSparkMax m_pivotMotor = new CANSparkMax(PivotConstants.PIVOT_ID, MotorType.kBrushless);
    private final RelativeEncoder m_encoder = m_pivotMotor.getEncoder();
    private final SparkPIDController m_pidController = m_pivotMotor.getPIDController();

    public PivotSubsystem() {
        // Factory reset to clear any old settings
        m_pivotMotor.restoreFactoryDefaults();

        // Brake mode is critical so gravity doesn't pull the shooter down easily
        m_pivotMotor.setIdleMode(IdleMode.kBrake);
        
        // NEO 550s burn out easily if stalled. Limit current to 20 Amps!
        m_pivotMotor.setSmartCurrentLimit(20);

        // Convert motor rotations to mechanism degrees: (1 rotation * 360) / 320
        m_encoder.setPositionConversionFactor(360.0 / PivotConstants.GEAR_RATIO);

        // Soft Limits: Prevent crashing into the robot chassis
        m_pivotMotor.setSoftLimit(CANSparkMax.SoftLimitDirection.kForward, PivotConstants.MAX_ANGLE_DEG);
        m_pivotMotor.setSoftLimit(CANSparkMax.SoftLimitDirection.kReverse, PivotConstants.MIN_ANGLE_DEG);
        m_pivotMotor.enableSoftLimit(CANSparkMax.SoftLimitDirection.kForward, true);
        m_pivotMotor.enableSoftLimit(CANSparkMax.SoftLimitDirection.kReverse, true);

        // PID Tuning (You will need to tune this on the real robot)
        m_pidController.setP(0.02);
        m_pidController.setI(0.0);
        m_pidController.setD(0.0);

        // Burn to flash so settings persist through brownouts
        m_pivotMotor.burnFlash();

        // ZERO THE ENCODER (Assuming manual alignment on boot)
        m_encoder.setPosition(0.0);
    }

    /**
     * Commands the pivot to a specific angle.
     * @param targetDegrees Angle between MIN_ANGLE_DEG and MAX_ANGLE_DEG
     */
    public void setTargetAngle(double targetDegrees) {
        m_pidController.setReference(targetDegrees, ControlType.kPosition);
    }

    public double getCurrentAngle() {
        return m_encoder.getPosition();
    }

    @Override
    public void periodic() {
        SmartDashboard.putNumber("Pivot/Current Angle", getCurrentAngle());
    }
}